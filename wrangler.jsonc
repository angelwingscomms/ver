{
	"$schema": "./node_modules/wrangler/config-schema.json",
	"name": "ver",
	"compatibility_date": "2026-07-12",
	"compatibility_flags": ["nodejs_als"],
	"main": ".svelte-kit/cloudflare/_worker.js",
	"assets": {
		"binding": "ASSETS",
		"directory": ".svelte-kit/cloudflare"
	},
	"secrets_store_secrets": [
		{ "binding": "QDRANT_URL", "store_id": "45748cb1c67946df943075fa14cb8815", "secret_name": "QDRANT_URL" },
		{ "binding": "QDRANT_KEY", "store_id": "45748cb1c67946df943075fa14cb8815", "secret_name": "QDRANT_KEY" },
		{ "binding": "OPENROUTER_KEY", "store_id": "45748cb1c67946df943075fa14cb8815", "secret_name": "OPENROUTER_KEY" }
	],
	"workers_dev": true,
	"preview_urls": true,
	"dev": {
		"port": 7272
	}
}
